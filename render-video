#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  cat <<'EOF'
Usage:
  ./render-video <audio-file> [preset] [output-file] [extra exporter flags...]

Examples:
  ./render-video ./Metallic_Drive_II.wav
  ./render-video ./Glitch-My-Veins.mp3 feed ./exports/feed.mp4
  ./render-video /path/to/song.wav reel ./exports/reel.mp4 --build space-build

Presets:
  reel       1080x1920
  feed       1080x1350
  square     1080x1080
  landscape  1920x1080

Notes:
  - If you omit the preset, it defaults to 'reel'.
  - If you omit the output file, the exporter creates one beside the audio file.
  - Any extra flags are passed through to tools/render-video.mjs.
EOF
}

if [[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  print_help
  exit 0
fi

INPUT_FILE="$1"
PRESET="${2:-reel}"
OUTPUT_FILE="${3:-}"
shift $(( $# >= 3 ? 3 : $# >= 2 ? 2 : 1 ))

CMD=(node "$ROOT_DIR/tools/render-video.mjs" --input "$INPUT_FILE" --preset "$PRESET")

if [[ -n "$OUTPUT_FILE" ]]; then
  CMD+=(--output "$OUTPUT_FILE")
fi

if [[ $# -gt 0 ]]; then
  CMD+=("$@")
fi

exec "${CMD[@]}"
